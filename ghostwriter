#!/usr/bin/env python3
"""
Ghostwriter v3 — CLI for managing email auto-reply contacts and tiers.

Phase 1: CLI + Tier 1 (multi-contact auto-reply)
Phase 2: Tier 3 Digest (deferred)
v4: Tier 2 Approval (deferred)

Design: ~/.ghostwriter/config.yaml is source of truth.
         <50 contacts, no SQLite. Python stdlib + pyyaml only.
"""

import argparse
import os
import subprocess
import sys
import yaml
import json
from datetime import datetime, timezone
from pathlib import Path

GHOSTWRITER_HOME = Path.home() / ".ghostwriter"
CONFIG_PATH = GHOSTWRITER_HOME / "config.yaml"
STATE_DIR = GHOSTWRITER_HOME / "state"
DRAFTS_DIR = GHOSTWRITER_HOME / "drafts"
HISTORY_DIR = GHOSTWRITER_HOME / "history"

DEFAULT_CONFIG = {
    "contacts": [],
}

VOICE_PRESETS = {
    "personal": {
        "name": "Personal",
        "description": "Warm, direct, casual. Inner circle.",
        "guidelines": (
            "Warm, direct, concise. No corporate AI-isms "
            '("I hope this finds you well", "I\'d be happy to assist"). '
            "Use contractions (I'll, don't, it's). Natural American English. "
            "Be specific, not hand-wavy. Own your opinions."
        ),
        "signature": "<p>Cheers,</p><p>Name</p>",
    },
    "professional": {
        "name": "Professional",
        "description": "Polished but not stiff. For colleagues, investors.",
        "guidelines": (
            "Professional but warm. Direct, clear, no fluff. "
            "Use contractions where natural. "
            "Be specific and actionable. No corporate jargon."
        ),
        "signature": "<p>Best regards,</p><p>Name</p>",
    },
}


# ── Helpers ────────────────────────────────────────────────

def load_config():
    """Load config.yaml. Returns default if not found."""
    if not CONFIG_PATH.exists():
        return DEFAULT_CONFIG.copy()
    with open(CONFIG_PATH) as f:
        return yaml.safe_load(f) or DEFAULT_CONFIG.copy()


def save_config(config):
    """Save config.yaml atomically."""
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp = CONFIG_PATH.with_suffix(".tmp")
    with open(tmp, "w") as f:
        yaml.dump(config, f, default_flow_style=False, allow_unicode=True, sort_keys=False)
    tmp.rename(CONFIG_PATH)


def find_contact(config, name):
    """Find a contact by name. Returns (index, contact_dict) or (None, None)."""
    for i, c in enumerate(config.get("contacts", [])):
        if c.get("name") == name:
            return i, c
    return None, None


def tier_label(tier):
    labels = {1: "Tier 1", 2: "Tier 2 (v4)", 3: "Tier 3 (digest)"}
    return labels.get(tier, f"Tier {tier}")


def status_label(contact):
    if contact.get("paused"):
        return "⏸ Paused"
    return "▶ Active"


# ── Commands ───────────────────────────────────────────────

def cmd_init(args):
    """Create ~/.ghostwriter/ directory structure and initial config."""
    if CONFIG_PATH.exists():
        print(f"✓ Already initialized: {CONFIG_PATH}")
        return

    GHOSTWRITER_HOME.mkdir(parents=True, exist_ok=True)
    STATE_DIR.mkdir(exist_ok=True)
    DRAFTS_DIR.mkdir(exist_ok=True)
    HISTORY_DIR.mkdir(exist_ok=True)

    save_config(DEFAULT_CONFIG)
    print(f"✓ Ghostwriter v3 initialized at {GHOSTWRITER_HOME}")
    print(f"  config:    {CONFIG_PATH}")
    print(f"  state:     {STATE_DIR}")
    print(f"  drafts:    {DRAFTS_DIR}")


def cmd_add(args):
    """Add a contact to config.yaml."""
    if args.tier not in (1, 2):
        print(f"Error: tier must be 1 or 2 (got {args.tier})")
        print("  Tier 3 is implicit — strangers are handled by the daily digest.")
        sys.exit(1)

    config = load_config()
    _, existing = find_contact(config, args.name)
    if existing:
        print(f"Error: contact '{args.name}' already exists. Use 'ghostwriter edit' to modify.")
        sys.exit(1)

    voice_preset = VOICE_PRESETS.get(args.voice, VOICE_PRESETS["personal"])
    signature = args.signature if args.signature else voice_preset["signature"]

    contact = {
        "name": args.name,
        "email": args.email,
        "tier": args.tier,
        "voice": args.voice,
        "signature": signature,
        "voice_guidelines": voice_preset["guidelines"],
        "added": datetime.now(timezone.utc).isoformat(),
        "paused": False,
    }

    config.setdefault("contacts", []).append(contact)
    save_config(config)

    # Also initialize state file
    state_file = STATE_DIR / f"{args.name}.json"
    state = {
        "name": args.name,
        "email": args.email,
        "tier": args.tier,
        "total_processed": 0,
        "last_processed": None,
        "paused": False,
        "created": datetime.now(timezone.utc).isoformat(),
    }
    with open(state_file, "w") as f:
        json.dump(state, f, indent=2)

    print(f"✓ Added {args.name} ({args.email}) as {tier_label(args.tier)}")
    print(f"  Voice: {voice_preset['name']}")
    if args.signature:
        print(f"  Signature: custom")


def cmd_list(args):
    """List all contacts in a table."""
    config = load_config()
    contacts = config.get("contacts", [])

    if not contacts:
        print("No contacts configured. Use 'ghostwriter add' to add one.")
        return

    # Header
    print(f"{'Name':<20} {'Email':<35} {'Tier':<12} {'Status':<12} {'Voice':<15} {'Processed':>10}")
    print("-" * 110)

    for c in contacts:
        name = c.get("name", "?")
        email = c.get("email", "?")
        tier = tier_label(c.get("tier", "?"))
        status = status_label(c)
        voice = c.get("voice", "?")

        # Read state for stats
        state_file = STATE_DIR / f"{name}.json"
        processed = "—"
        if state_file.exists():
            with open(state_file) as f:
                s = json.load(f)
                processed = str(s.get("total_processed", 0))

        print(f"{name:<20} {email:<35} {tier:<12} {status:<12} {voice:<15} {processed:>10}")


def cmd_show(args):
    """Show details for a contact."""
    config = load_config()
    _, contact = find_contact(config, args.name)
    if not contact:
        print(f"Error: contact '{args.name}' not found.")
        sys.exit(1)

    print(f"  Name:       {contact['name']}")
    print(f"  Email:      {contact['email']}")
    print(f"  Tier:       {tier_label(contact['tier'])}")
    print(f"  Voice:      {contact.get('voice', '?')}")
    print(f"  Signature:  {contact.get('signature', '?')}")
    print(f"  Paused:     {contact.get('paused', False)}")
    print(f"  Added:      {contact.get('added', '?')}")

    # State
    state_file = STATE_DIR / f"{args.name}.json"
    if state_file.exists():
        with open(state_file) as f:
            s = json.load(f)
        print(f"  —")
        print(f"  Processed:  {s.get('total_processed', 0)} emails")
        print(f"  Last:       {s.get('last_processed', 'never')}")


def cmd_edit(args):
    """Edit a contact's properties."""
    config = load_config()
    idx, contact = find_contact(config, args.name)
    if not contact:
        print(f"Error: contact '{args.name}' not found.")
        sys.exit(1)

    changed = False
    if args.tier is not None:
        config["contacts"][idx]["tier"] = args.tier
        print(f"✓ {args.name}: tier → {tier_label(args.tier)}")
        changed = True
    if args.voice is not None:
        voice_preset = VOICE_PRESETS.get(args.voice, VOICE_PRESETS["personal"])
        config["contacts"][idx]["voice"] = args.voice
        config["contacts"][idx]["voice_guidelines"] = voice_preset["guidelines"]
        if not args.signature:
            config["contacts"][idx]["signature"] = voice_preset["signature"]
        print(f"✓ {args.name}: voice → {voice_preset['name']}")
        changed = True
    if args.signature is not None:
        config["contacts"][idx]["signature"] = args.signature
        print(f"✓ {args.name}: signature updated")
        changed = True
    if args.email is not None:
        config["contacts"][idx]["email"] = args.email
        print(f"✓ {args.name}: email → {args.email}")
        changed = True

    if not changed:
        print("No changes specified. Use --tier, --voice, --signature, or --email.")
        sys.exit(1)

    save_config(config)


def cmd_pause(args):
    """Pause a contact — skip in cron ticks."""
    config = load_config()
    idx, contact = find_contact(config, args.name)
    if not contact:
        print(f"Error: contact '{args.name}' not found.")
        sys.exit(1)

    config["contacts"][idx]["paused"] = True
    save_config(config)

    # Update state too
    state_file = STATE_DIR / f"{args.name}.json"
    if state_file.exists():
        with open(state_file) as f:
            s = json.load(f)
        s["paused"] = True
        with open(state_file, "w") as f:
            json.dump(s, f, indent=2)

    print(f"✓ {args.name} paused — will be skipped in cron ticks.")


def cmd_resume(args):
    """Resume a paused contact."""
    config = load_config()
    idx, contact = find_contact(config, args.name)
    if not contact:
        print(f"Error: contact '{args.name}' not found.")
        sys.exit(1)

    config["contacts"][idx]["paused"] = False
    save_config(config)

    state_file = STATE_DIR / f"{args.name}.json"
    if state_file.exists():
        with open(state_file) as f:
            s = json.load(f)
        s["paused"] = False
        with open(state_file, "w") as f:
            json.dump(s, f, indent=2)

    print(f"✓ {args.name} resumed.")


def cmd_remove(args):
    """Remove a contact."""
    config = load_config()
    idx, contact = find_contact(config, args.name)
    if not contact:
        print(f"Error: contact '{args.name}' not found.")
        sys.exit(1)

    confirm = input(f"Remove {args.name} ({contact['email']})? [y/N] ")
    if confirm.lower() != "y":
        print("Cancelled.")
        return

    del config["contacts"][idx]
    save_config(config)

    # Clean up state
    state_file = STATE_DIR / f"{args.name}.json"
    if state_file.exists():
        state_file.unlink()
    memory_file = STATE_DIR / f"{args.name}.md"
    if memory_file.exists():
        memory_file.unlink()

    print(f"✓ Removed {args.name}.")


def cmd_stats(args):
    """Show ghostwriter statistics."""
    config = load_config()
    contacts = config.get("contacts", [])

    total_processed = 0
    active_t1 = 0
    active_t2 = 0
    paused = 0

    for c in contacts:
        state_file = STATE_DIR / f"{c['name']}.json"
        if state_file.exists():
            with open(state_file) as f:
                s = json.load(f)
            total_processed += s.get("total_processed", 0)

        if c.get("paused"):
            paused += 1
        elif c.get("tier") == 1:
            active_t1 += 1
        elif c.get("tier") == 2:
            active_t2 += 1

    print("Ghostwriter v3")
    print(f"  Contacts:     {len(contacts)} total")
    print(f"  Tier 1:       {active_t1} active")
    print(f"  Tier 2:       {active_t2} (deferred to v4)")
    print(f"  Paused:       {paused}")
    print(f"  Emails sent:  {total_processed}")
    print(f"  Config:       {CONFIG_PATH}")


def cmd_digest(args):
    """Manually trigger the Tier 3 digest."""
    script = Path(__file__).resolve().parent.parent / \
             "amber-os/_Projects/ghostwriter-cli-v3/scripts/digest.py"
    # Fallback: use absolute path since CLI lives in ~/.local/bin/
    script = Path.home() / "amber-os/_Projects/ghostwriter-cli-v3/scripts/digest.py"

    if not script.exists():
        print(f"Error: digest.py not found at {script}")
        sys.exit(1)

    print("Running Tier 3 digest...")
    env = os.environ.copy()
    env["GHOSTWRITER_DIGEST_VERBOSE"] = "1"

    result = subprocess.run(
        [str(Path.home() / ".hermes/hermes-agent/venv/bin/python3"), str(script)],
        capture_output=True, text=True, timeout=300, env=env,
    )

    if result.stdout:
        print(result.stdout)
    if result.stderr:
        print(result.stderr, file=sys.stderr)

    if result.returncode != 0:
        sys.exit(result.returncode)


def cmd_promote(args):
    """Promote a sender to Tier 1 — convenience wrapper around add."""
    ns = argparse.Namespace(
        email=args.email,
        name=args.name,
        tier=args.tier,
        voice=args.voice,
        signature=None,
    )
    cmd_add(ns)


# ── Main ───────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="ghostwriter",
        description="Ghostwriter v3 — autonomous email relationship manager",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    # init
    sub.add_parser("init", help="Create ~/.ghostwriter/ directory and config")

    # add
    p_add = sub.add_parser("add", help="Add a contact")
    p_add.add_argument("--email", required=True, help="Contact email")
    p_add.add_argument("--name", required=True, help="Short name for the contact")
    p_add.add_argument("--tier", type=int, required=True, choices=[1, 2],
                       help="1 = auto-reply, 2 = approval (deferred to v4)")
    p_add.add_argument("--voice", default="personal",
                       choices=list(VOICE_PRESETS.keys()),
                       help="Voice preset (default: personal)")
    p_add.add_argument("--signature", help="Custom HTML signature (overrides voice preset)")

    # list
    sub.add_parser("list", help="List all contacts")

    # show
    p_show = sub.add_parser("show", help="Show contact details")
    p_show.add_argument("name", help="Contact name")

    # edit
    p_edit = sub.add_parser("edit", help="Edit a contact")
    p_edit.add_argument("name", help="Contact name")
    p_edit.add_argument("--tier", type=int, choices=[1, 2])
    p_edit.add_argument("--voice", choices=list(VOICE_PRESETS.keys()))
    p_edit.add_argument("--signature", help="Custom HTML signature")
    p_edit.add_argument("--email", help="Change email address")

    # pause
    p_pause = sub.add_parser("pause", help="Pause a contact (skip in cron)")
    p_pause.add_argument("name", help="Contact name")

    # resume
    p_resume = sub.add_parser("resume", help="Resume a paused contact")
    p_resume.add_argument("name", help="Contact name")

    # remove
    p_rm = sub.add_parser("remove", help="Remove a contact")
    p_rm.add_argument("name", help="Contact name")

    # stats
    sub.add_parser("stats", help="Show statistics")

    # digest
    sub.add_parser("digest", help="Manually trigger Tier 3 digest")

    # promote
    p_promote = sub.add_parser("promote", help="Promote a sender to Tier 1 (from digest)")
    p_promote.add_argument("--email", required=True, help="Sender email")
    p_promote.add_argument("--name", required=True, help="Short name for the contact")
    p_promote.add_argument("--tier", type=int, default=1, choices=[1],
                           help="Tier to promote to (default: 1)")
    p_promote.add_argument("--voice", default="personal",
                           choices=list(VOICE_PRESETS.keys()),
                           help="Voice preset (default: personal)")

    args = parser.parse_args()

    commands = {
        "init": cmd_init,
        "add": cmd_add,
        "list": cmd_list,
        "show": cmd_show,
        "edit": cmd_edit,
        "pause": cmd_pause,
        "resume": cmd_resume,
        "remove": cmd_remove,
        "stats": cmd_stats,
        "digest": cmd_digest,
        "promote": cmd_promote,
    }

    commands[args.command](args)


if __name__ == "__main__":
    main()
